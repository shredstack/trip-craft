# Neon pooled connection string
DATABASE_URL=

# Neon direct connection (for migrations)
DIRECT_URL=

# Claude API key
ANTHROPIC_API_KEY=

# Google Places API key
GOOGLE_PLACES_API_KEY=

# Vercel Blob storage token (for caching Google Places images)
BLOB_READ_WRITE_TOKEN=

# Inngest (production only — tells Inngest SDK which URL to register)
INNGEST_SERVE_HOST=https://trip-craft.shredstack.net

# NextAuth (generate secret with: openssl rand -base64 32)
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Resend email service (for admin job notifications)
RESEND_API_KEY=
RESEND_FROM_EMAIL="TripCraft <tripcraft@shredstack.net>"
