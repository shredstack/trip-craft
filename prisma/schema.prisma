// TripCraft Database Schema
// PostgreSQL on Neon, managed via Prisma ORM
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")  // Neon connection string
  directUrl = env("DIRECT_URL")     // Neon direct connection (for migrations)
}

// ============================================
// USERS
// ============================================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?  @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  
  // Admin access
  isAdmin      Boolean  @default(false) @map("is_admin")

  // Preferences (stored as JSON for flexibility)
  departCity    String?  @default("Salt Lake City, UT") @map("depart_city")
  preferences   Json?    // { defaultBudget, tripTypes, priorities, etc. }
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trips       Trip[]
  inngestJobs InngestJob[]

  @@map("users")
}

// ============================================
// TRIPS - The core entity users manage
// ============================================
model Trip {
  id     String     @id @default(cuid())
  userId String     @map("user_id")
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  status      TripStatus @default(DREAMING)
  
  // Search criteria used to generate this trip
  criteria    Json?      // { adults, children, childAges, tripTypes, priorities, etc. }
  
  // Travel details
  departCity  String?    @map("depart_city")
  startDate   DateTime?  @map("start_date")
  endDate     DateTime?  @map("end_date")
  budgetType  String?    @map("budget_type")  // budget, moderate, premium, luxury
  totalBudget Decimal?   @map("total_budget") @db.Decimal(10, 2)
  
  notes       String?    @db.Text

  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  destinations  Destination[]
  tripItems     TripItem[]

  @@index([userId])
  @@index([status])
  @@map("trips")
}

enum TripStatus {
  DREAMING   // Just exploring ideas
  PLANNING   // Actively planning, comparing options
  BOOKED     // Confirmed and booked
  COMPLETED  // Trip is done
  ARCHIVED   // No longer active
}

// ============================================
// DESTINATIONS - Places recommended or saved
// ============================================
model Destination {
  id     String @id @default(cuid())
  tripId String @map("trip_id")
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  name        String
  region      String?
  country     String?
  description String?    @db.Text
  
  // AI-generated data
  matchScore  Int?       @map("match_score")      // 0-100 match percentage
  aiReasoning String?    @map("ai_reasoning") @db.Text  // Why AI recommended this
  
  // Cached external data (Google Places, etc.)
  placeId       String?  @map("place_id")         // Google Places ID
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  avgRating     Decimal? @map("avg_rating") @db.Decimal(2, 1)
  reviewCount   Int?     @map("review_count")
  photoUrls     Json?    @map("photo_urls")        // Array of image URLs
  reviews       Json?    @map("reviews")            // Array of { author, rating, text, time }
  
  // Travel logistics
  flightTime    String?  @map("flight_time")       // e.g. "4.5h"
  avgCostPp     Decimal? @map("avg_cost_pp") @db.Decimal(10, 2) // Per person
  bestMonths    String?  @map("best_months")       // e.g. "Mar-Apr"
  weatherData   Json?    @map("weather_data")       // { avgTemp, rainfall, etc. }
  
  // User preferences
  isSelected    Boolean  @default(false) @map("is_selected")  // User's chosen destination
  userNotes     String?  @map("user_notes") @db.Text
  sortOrder     Int      @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  excursions      Excursion[]
  accommodations  Accommodation[]

  @@index([tripId])
  @@map("destinations")
}

// ============================================
// EXCURSIONS - Activities at a destination
// ============================================
model Excursion {
  id            String      @id @default(cuid())
  destinationId String      @map("destination_id")
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  name          String
  description   String?     @db.Text
  type          ExcursionType
  
  // Pricing & logistics
  priceEstimate String?     @map("price_estimate")   // e.g. "$100/person"
  priceCents    Int?        @map("price_cents")       // Exact price in cents for sorting
  duration      String?                               // e.g. "Full day", "2-3 hours"
  
  // Family info
  kidFriendly   Boolean     @default(true) @map("kid_friendly")
  minAge        Int?        @map("min_age")           // Minimum recommended age
  kidNotes      String?     @map("kid_notes")         // Specific tips for families
  
  // External data
  placeId       String?     @map("place_id")
  bookingUrl    String?     @map("booking_url")
  avgRating     Decimal?    @map("avg_rating") @db.Decimal(2, 1)
  reviewCount   Int?        @map("review_count")
  photoUrls     Json?       @map("photo_urls")
  
  reviews       Json?       @map("reviews")         // Array of { author, rating, text, time }

  // AI data
  aiReasoning   String?     @map("ai_reasoning") @db.Text
  
  // User preferences
  isBooked      Boolean     @default(false) @map("is_booked")
  userNotes     String?     @map("user_notes") @db.Text
  sortOrder     Int         @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([destinationId])
  @@index([type])
  @@map("excursions")
}

enum ExcursionType {
  ADVENTURE
  CULTURE
  FOOD
  NATURE
  RELAXATION
  NIGHTLIFE
  SHOPPING
  TRANSPORTATION
  OTHER
}

// ============================================
// TRIP ITEMS - Flights, hotels, cars, etc.
// ============================================
model TripItem {
  id     String @id @default(cuid())
  tripId String @map("trip_id")
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  type        TripItemType
  name        String
  description String?       @db.Text
  
  // Booking details
  status      ItemStatus    @default(IDEA)
  bookingRef  String?       @map("booking_ref")
  bookingUrl  String?       @map("booking_url")
  provider    String?                             // e.g. "Delta", "Marriott", "Hertz"
  
  // Cost tracking
  costCents   Int?          @map("cost_cents")
  currency    String?       @default("USD")
  
  // Scheduling
  startDate   DateTime?     @map("start_date")
  endDate     DateTime?     @map("end_date")
  
  // Flexible metadata
  metadata    Json?         // { flightNumber, hotelAddress, carType, etc. }
  
  userNotes   String?       @map("user_notes") @db.Text
  sortOrder   Int           @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tripId])
  @@index([type])
  @@map("trip_items")
}

enum TripItemType {
  FLIGHT
  HOTEL
  CAR_RENTAL
  TRANSFER       // Airport shuttle, taxi, etc.
  RESTAURANT
  INSURANCE
  DOCUMENT       // Passport, visa, etc.
  PACKING        // Packing list items
  OTHER
}

enum ItemStatus {
  IDEA           // Just tracking as an option
  RESEARCHING    // Actively comparing
  BOOKED         // Confirmed
  CANCELLED
}

// ============================================
// ACCOMMODATIONS - Hotel/resort suggestions per destination
// ============================================
model Accommodation {
  id            String      @id @default(cuid())
  destinationId String      @map("destination_id")
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  name             String
  description      String?     @db.Text

  // Google Places data
  placeId          String?     @map("place_id")
  avgRating        Decimal?    @map("avg_rating") @db.Decimal(2, 1)
  reviewCount      Int?        @map("review_count")
  photoUrls        Json?       @map("photo_urls")
  priceLevel       Int?        @map("price_level")           // Google's 0-4 scale
  formattedAddress String?     @map("formatted_address")
  websiteUrl       String?     @map("website_url")
  reviews          Json?       @map("reviews")

  // Location
  latitude      Decimal?    @db.Decimal(10, 7)
  longitude     Decimal?    @db.Decimal(10, 7)

  sortOrder     Int         @default(0) @map("sort_order")

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@index([destinationId])
  @@map("accommodations")
}

// ============================================
// CATALOG DESTINATIONS - Curated destination database
// Used for deterministic filtering before AI recommendation
// ============================================
model CatalogDestination {
  id          String   @id @default(cuid())

  // Core identity
  name        String                              // e.g. "Bali"
  region      String                              // e.g. "Ubud, Indonesia"
  country     String                              // e.g. "Indonesia"
  continent   String                              // e.g. "Asia"
  description String   @db.Text                   // 2-3 sentence compelling description

  // === TRIP TYPE SCORES (1-10 each) ===
  scoreBeach      Int   @default(0) @map("score_beach")
  scoreAdventure  Int   @default(0) @map("score_adventure")
  scoreCulture    Int   @default(0) @map("score_culture")
  scoreNature     Int   @default(0) @map("score_nature")
  scoreCity       Int   @default(0) @map("score_city")
  scoreResort     Int   @default(0) @map("score_resort")
  scoreThemePark  Int   @default(0) @map("score_theme_park")
  scoreCruise     Int   @default(0) @map("score_cruise")

  // === PRIORITY SCORES (1-10 each) ===
  scoreKidFriendly  Int   @default(0) @map("score_kid_friendly")
  scoreRelaxation   Int   @default(0) @map("score_relaxation")
  scoreFood         Int   @default(0) @map("score_food")
  scoreSafety       Int   @default(0) @map("score_safety")
  scoreScenic       Int   @default(0) @map("score_scenic")
  scoreNightlife    Int   @default(0) @map("score_nightlife")

  // === HARD CONSTRAINT FILTERS ===
  costTier        String                          // "budget" | "moderate" | "premium" | "luxury"
  avgDailyCostUsd Int      @map("avg_daily_cost_usd")  // Per person estimate
  bestMonths      String   @map("best_months")         // e.g. "Nov,Dec,Jan,Feb,Mar"
  avoidMonths     String?  @map("avoid_months")        // e.g. "Jun,Jul,Aug" (monsoon, etc.)
  minRecommendedAge Int?   @map("min_recommended_age") // null = suitable for all ages

  // === LOGISTICS ===
  // Flight times from common US airports (hours, null if not practical)
  flightTimeNYC     Decimal? @map("flight_time_nyc")   @db.Decimal(3, 1)
  flightTimeLAX     Decimal? @map("flight_time_lax")   @db.Decimal(3, 1)
  flightTimeSLC     Decimal? @map("flight_time_slc")   @db.Decimal(3, 1)
  flightTimeORD     Decimal? @map("flight_time_ord")   @db.Decimal(3, 1)
  flightTimeDFW     Decimal? @map("flight_time_dfw")   @db.Decimal(3, 1)
  flightTimeMIA     Decimal? @map("flight_time_mia")   @db.Decimal(3, 1)
  flightTimeATL     Decimal? @map("flight_time_atl")   @db.Decimal(3, 1)
  flightTimeSEA     Decimal? @map("flight_time_sea")   @db.Decimal(3, 1)

  visaRequired    Boolean  @default(false) @map("visa_required")   // For US passport holders
  visaNotes       String?  @map("visa_notes")                      // e.g. "Visa on arrival, 30 days"
  languageNotes   String?  @map("language_notes")                  // e.g. "English widely spoken"
  healthNotes     String?  @map("health_notes")                    // e.g. "Malaria prophylaxis recommended"

  // === TAGS ===
  tags            Json     @default("[]")

  // === GOOGLE PLACES DATA ===
  placeId         String?  @map("place_id")
  latitude        Decimal? @db.Decimal(10, 7)
  longitude       Decimal? @db.Decimal(10, 7)
  avgRating       Decimal? @map("avg_rating") @db.Decimal(2, 1)
  reviewCount     Int?     @map("review_count")
  photoUrls       Json?    @map("photo_urls")           // Array of image URLs

  // === ADMIN METADATA ===
  status          String   @default("draft")             // "draft" | "published" | "archived"
  generatedFrom   String?  @map("generated_from")        // The prompt/region used to generate this
  adminNotes      String?  @map("admin_notes") @db.Text  // Admin's personal notes

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([continent])
  @@index([costTier])
  @@index([country])
  @@unique([name, country])  // Prevent duplicates
  @@map("catalog_destinations")
}

// ============================================
// CATALOG GENERATION JOBS - Track admin AI generation requests
// ============================================
model CatalogGenerationJob {
  id        String   @id @default(cuid())
  status    String   @default("pending")   // "pending" | "running" | "completed" | "failed"
  prompt    String
  count     Int
  results   Json?                           // GeneratedCatalogDestination[] when completed
  error     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("catalog_generation_jobs")
}

// ============================================
// INNGEST JOBS - Unified tracking for all background jobs
// ============================================
model InngestJob {
  id              String          @id @default(cuid())
  type            InngestJobType
  status          InngestJobStatus @default(PENDING)

  // Who triggered it
  userId          String?         @map("user_id")
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Context references
  tripId          String?         @map("trip_id")
  inngestEventId  String?         @map("inngest_event_id")

  // LLM details
  llmPrompt       String?         @map("llm_prompt") @db.Text
  llmModel        String?         @map("llm_model")
  totalInputTokens  Int?          @map("total_input_tokens")
  totalOutputTokens Int?          @map("total_output_tokens")

  // Timing
  durationMs      Int?            @map("duration_ms")

  // Error info
  error           String?         @db.Text

  // Flexible metadata
  metadata        Json?

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  events          InngestJobEvent[]

  @@index([type])
  @@index([status])
  @@index([userId])
  @@index([tripId])
  @@index([createdAt])
  @@map("inngest_jobs")
}

model InngestJobEvent {
  id            String   @id @default(cuid())
  jobId         String   @map("job_id")
  job           InngestJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  status        String                    // PENDING, RUNNING, STEP_COMPLETED, COMPLETED, FAILED
  stepName      String?  @map("step_name")
  message       String?  @db.Text

  // Per-step LLM token tracking
  inputTokens   Int?     @map("input_tokens")
  outputTokens  Int?     @map("output_tokens")

  // Step duration
  durationMs    Int?     @map("duration_ms")

  // Step-specific data
  metadata      Json?

  createdAt     DateTime @default(now()) @map("created_at")

  @@index([jobId])
  @@index([status])
  @@index([createdAt])
  @@map("inngest_job_events")
}

enum InngestJobType {
  TRIP_GENERATION
  CATALOG_GENERATION
}

enum InngestJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
